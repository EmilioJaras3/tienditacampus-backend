# ============================================================
# TienditaCampus - Backend Production Environment Config
# ============================================================
NODE_ENV=production
BACKEND_PORT=3001

# ── Amazon RDS (PostgreSQL) ──────────────────
# Usar el Endpoint que provee AWS RDS
POSTGRES_HOST=tienditacampus-db.xxxxxxxxxxxx.us-east-1.rds.amazonaws.com
POSTGRES_PORT=5432
POSTGRES_DB=tienditacampus
POSTGRES_USER=postgres_master
POSTGRES_PASSWORD=una_contraseña_fuerte_de_produccion

# ── MongoDB Atlas ────────────────────────────
# Cadena de conexión obtenida de Atlas
MONGO_URI=mongodb+srv://243692_db_user:sESfVxDkfP5eCSpC@tienditacampus-mongo-db.rqhlmj6.mongodb.net/tienditacampus_logs?appName=tienditacampus-mongo-db

# ── Seguridad y Otros ────────────────────────
JWT_SECRET=super_secret_produccion_token_larga
JWT_EXPIRATION=7d
BCRYPT_SALT_ROUNDS=12

# URLs Frontends permitidos en CORS
FRONTEND_URL=https://tienditacampus.vercel.app
