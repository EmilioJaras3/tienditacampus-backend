# ============================================================
# TienditaCampus - Backend (NestJS)
# ============================================================
# INSTRUCCIONES:
# 1. Copia este archivo: cp .env.example .env
# 2. Los valores se heredan del .env raíz via docker-compose
# 3. Para desarrollo local sin Docker, configura los valores aquí
# ============================================================

# ── Database ─────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tienditacampus
POSTGRES_USER=               # Configurar manualmente o vía Docker
POSTGRES_PASSWORD=           # Configurar manualmente o vía Docker

# ── Application ──────────────────────────────
BACKEND_PORT=3001
NODE_ENV=development

# ── JWT ──────────────────────────────────────
JWT_SECRET=                  # Generar con: openssl rand -hex 64
JWT_EXPIRATION=7d

# ── Security ─────────────────────────────────
BCRYPT_SALT_ROUNDS=12
ARGON2_MEMORY_COST=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1

# ── Google Cloud / BigQuery ──────────────────
GCP_PROJECT_ID=data-from-software
BIGQUERY_DATASET=benchmarking_warehouse
BIGQUERY_TABLE=daily_query_metrics
GOOGLE_CLIENT_ID=tu_client_id_aqui
GOOGLE_CLIENT_SECRET=tu_client_secret_aqui
GOOGLE_REDIRECT_URI=http://localhost:3001/api/benchmarking/auth/callback
